{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [".*\\.nix$"],
      "matchStrings": [
        "\\bpython(?<major>\\d)(?<minor>\\d+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "python/cpython",
      "currentValueTemplate": "{{major}}.{{minor}}"
    },
    {
      "description": "Update fetchFromGitHub rev fields under overlays/",
      "customType": "regex",
      "fileMatch": ["^overlays/.*\\.nix$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+rev = \\\"(?<currentValue>[^\\\"]+)\\\";"
      ]
    },
    {
      "description": "Update derived version variables used by fetchFromGitHub rev fields under overlays/",
      "customType": "regex",
      "fileMatch": ["^overlays/.*\\.nix$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) extractVersion=(?<extractVersion>\\S+)\\s+version = \\\"(?<currentValue>[^\\\"]+)\\\";"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Major & minor only",
      "matchDepNames": ["python/cpython"],
      "matchUpdateTypes": ["patch", "pin"],
      "enabled": false
    },
    {
      "description": "Major only",
      "matchDepNames": ["llvm/llvm-project"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "enabled": false
    }
  ]
}
