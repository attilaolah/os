{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/.*\\.nix$/"
      ],
      "matchStrings": [
        "\\bpython(?<major>\\d)(?<minor>\\d+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "python/cpython",
      "currentValueTemplate": "{{major}}.{{minor}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/.*\\.nix$/"
      ],
      "matchStrings": [
        "\\bnodejs_(?<major>\\d+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "nodejs/node",
      "currentValueTemplate": "{{major}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/.*\\.nix$/"
      ],
      "matchStrings": [
        "\\bclang_(?<major>\\d+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "llvm/llvm-project",
      "currentValueTemplate": "{{major}}"
    },
    {
      "description": "Update tuple-style GitHub dependencies under overlays/",
      "customType": "regex",
      "managerFilePatterns": [
        "/^overlays/.*\\.nix$/"
      ],
      "matchStrings": [
        "github-tags\\s*=\\s*\\[\\s*\\\"(?<depName>[^\\\"]+)\\\"\\s+\\\"(?<currentValue>[^\\\"]+)\\\"\\s*\\]\\s*;(?:\\s*#\\s*extractVersion=(?<extractVersion>\\S+))?"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "description": "Update GitHub flake inputs pinned to tags",
      "customType": "regex",
      "managerFilePatterns": [
        "/^flake\\.nix$/"
      ],
      "matchStrings": [
        "url\\s*=\\s*\\\"github:(?<depName>[^\\\"\\/]+\\/[^\\\"\\/]+)\\/(?<currentValue>v?\\d[^\\\"]*)\\\";"
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "description": "Update pinned nixpkgs CUDA package set",
      "customType": "regex",
      "managerFilePatterns": [
        "/^hosts/home/configuration\\.nix$/"
      ],
      "matchStrings": [
        "cudaPackages\\s*=\\s*prev\\.lib\\.recurseIntoAttrs\\s+prev\\.cudaPackages_(?<currentValue>\\d+_\\d+);"
      ],
      "datasourceTemplate": "custom.nixpkgs-cuda-packages",
      "depNameTemplate": "nixpkgs CUDA package set",
      "versioningTemplate": "regex:^(?<major>\\d+)_(?<minor>\\d+)$"
    }
  ],
  "customDatasources": {
    "nixpkgs-cuda-packages": {
      "defaultRegistryUrlTemplate": "https://raw.githubusercontent.com/NixOS/nixpkgs/nixos-unstable/pkgs/top-level/all-packages.nix",
      "format": "plain"
    }
  },
  "packageRules": [
    {
      "description": "Major & minor only",
      "matchDepNames": ["python/cpython"],
      "matchUpdateTypes": ["patch", "pin"],
      "enabled": false
    },
    {
      "description": "Keep llama.cpp updates in one rolling PR",
      "matchDepNames": ["ggml-org/llama.cpp"],
      "separateMajorMinor": false,
      "separateMultipleMajor": false,
      "groupName": "llama.cpp",
      "branchTopic": "llama-cpp"
    },
    {
      "description": "Extract nixpkgs CUDA package set versions",
      "matchDepNames": ["nixpkgs CUDA package set"],
      "matchDatasources": ["custom.nixpkgs-cuda-packages"],
      "extractVersion": "^cudaPackages_(?<version>\\d+_\\d+)$",
      "groupName": "CUDA package set",
      "branchTopic": "cuda-package-set"
    },
    {
      "description": "Major only",
      "matchDepNames": ["llvm/llvm-project", "nodejs/node"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "enabled": false
    }
  ]
}
