{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [".*\\.nix$"],
      "matchStrings": [
        "\\bpython(?<major>\\d)(?<minor>\\d+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "python/cpython",
      "currentValueTemplate": "{{major}}.{{minor}}"
    },
    {
      "customType": "regex",
      "fileMatch": [".*\\.nix$"],
      "matchStrings": [
        "\\bnodejs_(?<major>\\d+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "nodejs/node",
      "currentValueTemplate": "{{major}}"
    },
    {
      "customType": "regex",
      "fileMatch": [".*\\.nix$"],
      "matchStrings": [
        "\\bclang_(?<major>\\d+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "llvm/llvm-project",
      "currentValueTemplate": "{{major}}"
    },
    {
      "description": "Update tuple-style GitHub dependencies under overlays/",
      "customType": "regex",
      "fileMatch": ["^overlays/.*\\.nix$"],
      "matchStrings": [
        "github-tags = \\[\\\"(?<depName>[^\\\"]+)\\\" \\\"(?<currentValue>[^\\\"]+)\\\"\\];(?:\\s+# extractVersion=(?<extractVersion>\\S+))?"
      ],
      "datasourceTemplate": "github-tags"
    }
  ],
  "packageRules": [
    {
      "description": "Major & minor only",
      "matchDepNames": ["python/cpython"],
      "matchUpdateTypes": ["patch", "pin"],
      "enabled": false
    },
    {
      "description": "Major only",
      "matchDepNames": ["llvm/llvm-project", "nodejs/node"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "enabled": false
    }
  ]
}
